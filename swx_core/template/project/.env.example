# =============================================================================
# SwX Framework Configuration
# Copy this file to .env and update values for your environment
# =============================================================================

# Application
PROJECT_NAME={{project_name}}
ENVIRONMENT=local
DOCKERIZED=false

# API Configuration
ROUTE_PREFIX=/api
API_VERSIONS=["v1"]
DEFAULT_API_VERSION=v1

# Security
# Generate new secrets for production! Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
REFRESH_SECRET_KEY=your-refresh-secret-key-change-this-in-production
PASSWORD_RESET_SECRET_KEY=your-password-reset-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (comma-separated origins)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
BACKEND_HOST=http://localhost:8000
FRONTEND_HOST=http://localhost:5173

# Database
DATABASE_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER={{project_slug}}_user
DB_PASSWORD=changeme
DB_NAME={{project_slug}}_db

# Redis
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email (optional)
SMTP_TLS=true
SMTP_SSL=false
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@{{project_slug}}.com
EMAILS_FROM_NAME={{project_title}}

# Superuser (for initial setup)
FIRST_SUPERUSER=admin@{{project_slug}}.com
FIRST_SUPERUSER_PASSWORD=changethispassword

# Logging
LOG_LEVEL=info